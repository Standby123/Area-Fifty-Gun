[sub_resource type="GDScript" id="GDScript_xf6qn"]
script/source = "extends TileMapLayer

@export var y_shift: float
@export var frameRate: float = 0.1
var amount_moved: float = 0
var step: float = 1

func move():
	while amount_moved < y_shift:
		transform[2][1] += step
		amount_moved += step
		await get_tree().create_timer(frameRate).timeout
"

